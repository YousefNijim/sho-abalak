{
  "expo": {
    "name": "شو عبالك؟ — الزبون",
    "slug": "shu-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "shu-customer",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FCF3DC",
    "splash": {
      "backgroundColor": "#FCF3DC",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.shu.customer",
      "adaptiveIcon": {
        "backgroundColor": "#FCF3DC"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
