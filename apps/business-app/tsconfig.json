{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-native",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@shu/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@shu/utils": ["../../packages/utils/src/index.ts"],
      "@shu/ui-components": ["../../packages/ui-components/src/index.ts"],
      "@shu/ui-components/native": ["../../packages/ui-components/src/native/index.ts"],
      "@shu/api-client": ["../../packages/api-client/src/index.ts"],
      "react-native-reanimated": ["node_modules/react-native-reanimated"]
    }
  },
  "include": ["app/**/*", "src/**/*", "*.ts", "*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
