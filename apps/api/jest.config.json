{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": ".*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": ["src/**/*.(t|j)s"],
  "coverageDirectory": "./coverage",
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@shu/shared-types$": "<rootDir>/../../packages/shared-types/src/index.ts",
    "^@shu/utils$": "<rootDir>/../../packages/utils/src/index.ts"
  }
}
