generator client {
  provider      = "prisma-client-js"
  // "native" = the local dev machine; the musl target is for the Alpine
  // (node:20-alpine) container on Railway, which uses musl libc + openssl 3.x.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Area {
  id                 String         @id @default(uuid())
  city               String
  name               String
  deliveryFee        Decimal        @db.Decimal(10, 2)
  businesses         Business[]     @relation("BusinessLocation")
  drivers            Driver[]
  savedAddresses     SavedAddress[]
  users              User[]
  deliveryBusinesses Business[]     @relation("BusinessDeliveryAreas")

  @@map("areas")
}

model User {
  id             String         @id @default(uuid())
  role           UserRole
  name           String
  phone          String         @unique
  email          String?        @unique
  imageUrl       String?
  password       String?
  areaId         String?
  createdAt      DateTime       @default(now())
  status         UserStatus     @default(ACTIVE)
  business       Business?
  deviceTokens   DeviceToken[]
  driver         Driver?
  orders         Order[]        @relation("CustomerOrders")
  savedAddresses SavedAddress[]
  area           Area?          @relation(fields: [areaId], references: [id])

  @@map("users")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String?
  app       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

model Business {
  id             String       @id @default(uuid())
  ownerId        String       @unique
  name           String
  areaId         String
  deliveryType   DeliveryType @default(PLATFORM)
  imageUrl       String?
  rating         Float        @default(0)
  isOpen         Boolean      @default(true)
  commissionRate Decimal      @default(10.00) @db.Decimal(5, 2)
  phone          String?
  addressDetail  String?
  closeTime      String?
  lat            Float?
  lng            Float?
  logoUrl        String?
  openTime       String?
  type           BusinessType @default(FOOD)
  area           Area         @relation("BusinessLocation", fields: [areaId], references: [id])
  owner          User         @relation(fields: [ownerId], references: [id])
  orders         Order[]
  products       Product[]
  deliveryAreas  Area[]       @relation("BusinessDeliveryAreas")
  tags           Tag[]        @relation("BusinessTags")

  @@map("businesses")
}

model Tag {
  id         String       @id @default(uuid())
  name       String
  type       BusinessType
  imageUrl   String?
  businesses Business[]   @relation("BusinessTags")

  @@unique([name, type])
  @@map("tags")
}

model Banner {
  id        String   @id @default(uuid())
  imageUrl  String
  linkUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("banners")
}

model Product {
  id          String      @id @default(uuid())
  businessId  String
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  imageUrl    String?
  isAvailable Boolean     @default(true)
  category    String?
  orderItems  OrderItem[]
  business    Business    @relation(fields: [businessId], references: [id])

  @@map("products")
}

model Driver {
  id     String       @id @default(uuid())
  userId String       @unique
  status DriverStatus @default(OFFLINE)
  areaId String
  rating Float        @default(0)
  area   Area         @relation(fields: [areaId], references: [id])
  user   User         @relation(fields: [userId], references: [id])
  orders Order[]

  @@map("drivers")
}

model Order {
  id                    String               @id @default(uuid())
  customerId            String
  businessId            String
  driverId              String?
  status                OrderStatus          @default(PENDING)
  paymentMethod         PaymentMethod
  total                 Decimal              @db.Decimal(10, 2)
  note                  String?
  createdAt             DateTime             @default(now())
  pendingDriverId       String?
  deliveryAreaName      String?
  deliveryAddressDetail String?
  items                 OrderItem[]
  statusHistory         OrderStatusHistory[]
  business              Business             @relation(fields: [businessId], references: [id])
  customer              User                 @relation("CustomerOrders", fields: [customerId], references: [id])
  driver                Driver?              @relation(fields: [driverId], references: [id])
  payment               Payment?
  review                Review?

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  changedBy String
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id])

  @@map("order_status_history")
}

model Review {
  id             String   @id @default(uuid())
  orderId        String   @unique
  businessRating Int
  driverRating   Int?
  comment        String?
  createdAt      DateTime @default(now())
  order          Order    @relation(fields: [orderId], references: [id])

  @@map("reviews")
}

model SavedAddress {
  id        String   @id @default(uuid())
  userId    String
  label     String
  detail    String
  areaId    String?
  createdAt DateTime @default(now())
  area      Area?    @relation(fields: [areaId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_addresses")
}

model Payment {
  id        String        @id @default(uuid())
  orderId   String        @unique
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  amount    Decimal       @db.Decimal(10, 2)
  createdAt DateTime      @default(now())
  provider  String?
  reference String?       @unique
  updatedAt DateTime      @updatedAt
  order     Order         @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model SystemSettings {
  id                String   @id @default("default")
  defaultCommission Decimal  @default(10.00) @db.Decimal(5, 2)
  baseDeliveryFee   Decimal  @default(3.00) @db.Decimal(10, 2)
  customerAppActive Boolean  @default(true)
  businessAppActive Boolean  @default(true)
  driverAppActive   Boolean  @default(true)
  updatedAt         DateTime @updatedAt

  @@map("system_settings")
}

enum UserRole {
  CUSTOMER
  BUSINESS
  DRIVER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  ELECTRONIC
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DriverStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum BusinessType {
  FOOD
  STORE
}

enum DeliveryType {
  PLATFORM
  SELF
}
