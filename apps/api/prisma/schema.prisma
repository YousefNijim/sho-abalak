// شو عبالك؟ — Prisma Schema
// راجع PROJECT_HANDOFF.md §نموذج قاعدة البيانات

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  BUSINESS
  DRIVER
  ADMIN
}

// حالة حساب المستخدم (يديرها الأدمن)
enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  ELECTRONIC
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DriverStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

// القسم الأعلى للمنشأة: مطاعم/مأكولات/كافيهات (FOOD) أو متاجر/سوبرماركت (STORE)
enum BusinessType {
  FOOD
  STORE
}

enum DeliveryType {
  PLATFORM
  SELF
}

model Area {
  id          String     @id @default(uuid())
  city        String
  name        String
  deliveryFee Decimal    @db.Decimal(10, 2)
  users              User[]
  businesses         Business[] @relation("BusinessLocation")
  deliveryBusinesses Business[] @relation("BusinessDeliveryAreas")
  drivers            Driver[]
  savedAddresses     SavedAddress[]

  @@map("areas")
}

model User {
  id        String     @id @default(uuid())
  role      UserRole
  status    UserStatus @default(ACTIVE)
  name      String
  phone     String     @unique
  email     String?    @unique
  password  String?
  areaId    String?
  area      Area?      @relation(fields: [areaId], references: [id])
  business        Business?
  driver          Driver?
  orders          Order[]         @relation("CustomerOrders")
  savedAddresses  SavedAddress[]
  createdAt       DateTime        @default(now())

  @@map("users")
}

model Business {
  id             String           @id @default(uuid())
  ownerId        String           @unique
  owner          User             @relation(fields: [ownerId], references: [id])
  name           String
  type           BusinessType     @default(FOOD)
  tags           Tag[]            @relation("BusinessTags")
  areaId         String
  area           Area             @relation("BusinessLocation", fields: [areaId], references: [id])
  deliveryAreas  Area[]           @relation("BusinessDeliveryAreas")
  deliveryType   DeliveryType     @default(PLATFORM)
  imageUrl       String?
  logoUrl        String?
  phone          String?
  addressDetail  String?
  lat            Float?
  lng            Float?
  openTime       String?
  closeTime      String?
  rating         Float            @default(0)
  isOpen         Boolean          @default(true)
  commissionRate Decimal          @db.Decimal(5, 2) @default(10.00)
  products       Product[]
  orders         Order[]

  @@map("businesses")
}

// وسوم المنشأة (شرقي، شاورما، سوبرماركت...) — قوائم معرّفة مسبقاً حسب القسم
model Tag {
  id         String       @id @default(uuid())
  name       String
  type       BusinessType
  businesses Business[]   @relation("BusinessTags")

  @@unique([name, type])
  @@map("tags")
}

model Product {
  id          String      @id @default(uuid())
  businessId  String
  business    Business    @relation(fields: [businessId], references: [id])
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  imageUrl    String?
  isAvailable Boolean     @default(true)
  category    String?
  orderItems  OrderItem[]

  @@map("products")
}

model Driver {
  id     String       @id @default(uuid())
  userId String       @unique
  user   User         @relation(fields: [userId], references: [id])
  status DriverStatus @default(OFFLINE)
  areaId String
  area   Area         @relation(fields: [areaId], references: [id])
  rating Float        @default(0)
  orders Order[]

  @@map("drivers")
}

model Order {
  id            String               @id @default(uuid())
  customerId    String
  customer      User                 @relation("CustomerOrders", fields: [customerId], references: [id])
  businessId    String
  business      Business             @relation(fields: [businessId], references: [id])
  driverId          String?
  driver            Driver?              @relation(fields: [driverId], references: [id])
  pendingDriverId   String?
  status                OrderStatus          @default(PENDING)
  paymentMethod         PaymentMethod
  total                 Decimal              @db.Decimal(10, 2)
  note                  String?
  deliveryAreaName      String?
  deliveryAddressDetail String?
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  review        Review?
  payment       Payment?
  createdAt     DateTime             @default(now())

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)

  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id])
  status    OrderStatus
  changedBy String
  createdAt DateTime    @default(now())

  @@map("order_status_history")
}

model Review {
  id             String   @id @default(uuid())
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id])
  businessRating Int
  driverRating   Int?
  comment        String?
  createdAt      DateTime @default(now())

  @@map("reviews")
}

model SavedAddress {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  detail    String
  areaId    String?
  area      Area?    @relation(fields: [areaId], references: [id])
  createdAt DateTime @default(now())

  @@map("saved_addresses")
}

model Payment {
  id        String        @id @default(uuid())
  orderId   String        @unique
  order     Order         @relation(fields: [orderId], references: [id])
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  amount    Decimal       @db.Decimal(10, 2)
  // Online gateway fields (null for cash). `reference` is the provider-side id used to
  // match a webhook/confirmation back to this payment; `provider` records which gateway.
  provider  String?
  reference String?       @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("payments")
}

model SystemSettings {
  id                String   @id @default("default")
  defaultCommission Decimal  @db.Decimal(5, 2) @default(10.00)
  baseDeliveryFee   Decimal  @db.Decimal(10, 2) @default(3.00)
  customerAppActive Boolean  @default(true)
  businessAppActive Boolean  @default(true)
  driverAppActive   Boolean  @default(true)
  updatedAt         DateTime @updatedAt

  @@map("system_settings")
}
