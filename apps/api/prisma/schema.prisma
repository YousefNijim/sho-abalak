generator client {
  provider      = "prisma-client-js"
  // "native" = the local dev machine; the musl target is for the Alpine
  // (node:20-alpine) container on Railway, which uses musl libc + openssl 3.x.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Area {
  id                 String         @id @default(uuid())
  city               String
  name               String
  deliveryFee        Decimal        @db.Decimal(10, 2)
  driverDeliveryFee  Decimal        @default(0) @db.Decimal(10, 2)
  businesses         Business[]        @relation("BusinessLocation")
  drivers            Driver[]
  savedAddresses     SavedAddress[]
  users              User[]
  deliveryBusinesses Business[]        @relation("BusinessDeliveryAreas")

  @@map("areas")
}

model User {
  id             String         @id @default(uuid())
  role           UserRole
  name           String
  phone          String         @unique
  email          String?        @unique
  imageUrl       String?
  password       String?
  areaId         String?
  createdAt      DateTime       @default(now())
  status         UserStatus     @default(ACTIVE)
  business       Business?
  deviceTokens   DeviceToken[]
  driver         Driver?
  orders         Order[]        @relation("CustomerOrders")
  savedAddresses SavedAddress[]
  area           Area?          @relation(fields: [areaId], references: [id])

  @@map("users")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String?
  app       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

model Business {
  id             String       @id @default(uuid())
  ownerId        String       @unique
  name           String
  areaId         String
  deliveryType   DeliveryType @default(PLATFORM)
  imageUrl       String?
  rating         Float        @default(0)
  isOpen         Boolean      @default(true)
  commissionRate Decimal      @default(10.00) @db.Decimal(5, 2)
  minimumOrder   Decimal?     @db.Decimal(10, 2)
  phone          String?
  addressDetail  String?
  closeTime      String?
  lat            Float?
  lng            Float?
  logoUrl        String?
  openTime       String?
  type           BusinessType @default(FOOD)
  area           Area         @relation("BusinessLocation", fields: [areaId], references: [id])
  owner          User         @relation(fields: [ownerId], references: [id])
  orders         Order[]
  products       Product[]
  deliveryAreas       Area[]             @relation("BusinessDeliveryAreas")
  tags                Tag[]              @relation("BusinessTags")
  driverReviews       DriverReview[]
  offerBusinesses     OfferBusiness[]
  promotedBusinesses  PromotedBusiness[]
  settlements         BusinessSettlement[]
  productCategories   ProductCategory[]
  categoryGroups      BusinessCategoryGroup[]
  categoryOverrides   BusinessCategoryOverride[]
  platformBalance     Decimal        @default(0) @db.Decimal(10, 2)

  @@map("businesses")
}

model Tag {
  id         String       @id @default(uuid())
  name       String
  type       BusinessType
  imageUrl   String?
  businesses Business[]   @relation("BusinessTags")

  @@unique([name, type])
  @@map("tags")
}

model Banner {
  id        String   @id @default(uuid())
  imageUrl  String
  linkUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("banners")
}

model PopupAd {
  id            String    @id @default(uuid())
  imageUrl      String
  title         String?
  buttonText    String?
  buttonUrl     String?
  targetPage    String    @default("home")  // home | cart | orders | business_detail | all
  isActive      Boolean   @default(true)
  intervalHours Int       @default(0)      // 0 = always, 24 = once/day
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("popup_ads")
}

model PromotedBusiness {
  id         String    @id @default(uuid())
  businessId String
  isPopup    Boolean   @default(false)    // also show as popup overlay
  isActive   Boolean   @default(true)
  priority   Int       @default(0)        // higher = shown first
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("promoted_businesses")
}

model ProductCategory {
  id         String            @id @default(uuid())
  businessId String
  name       String
  parentId   String?
  sortOrder  Int               @default(0)
  imageUrl   String?
  business   Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  parent     ProductCategory?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: SetNull)
  children   ProductCategory[] @relation("SubCategories")
  products   Product[]

  @@index([businessId])
  @@index([parentId])
  @@map("product_categories")
}

// ── Admin-controlled category system ──────────────────────────────────────────

model CategoryGroup {
  id          String    @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  templates   CategoryTemplate[]
  assignments BusinessCategoryGroup[]

  @@map("category_groups")
}

model CategoryTemplate {
  id        String   @id @default(uuid())
  groupId   String
  name      String
  imageUrl  String?
  parentId  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  group     CategoryGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  parent    CategoryTemplate?  @relation("SubTemplates", fields: [parentId], references: [id], onDelete: SetNull)
  children  CategoryTemplate[] @relation("SubTemplates")
  products  Product[]
  overrides BusinessCategoryOverride[]

  @@index([groupId])
  @@index([parentId])
  @@map("category_templates")
}

model BusinessCategoryGroup {
  id         String   @id @default(uuid())
  businessId String
  groupId    String
  isActive   Boolean  @default(true)
  assignedAt DateTime @default(now())

  business Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  group    CategoryGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([businessId, groupId])
  @@map("business_category_groups")
}

model BusinessCategoryOverride {
  id                 String   @id @default(uuid())
  businessId         String
  categoryTemplateId String
  isEnabled          Boolean  @default(true)

  business         Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  categoryTemplate CategoryTemplate @relation(fields: [categoryTemplateId], references: [id], onDelete: Cascade)

  @@unique([businessId, categoryTemplateId])
  @@map("business_category_overrides")
}

model ProductVariant {
  id          String      @id @default(uuid())
  productId   String
  name        String
  price       Decimal     @db.Decimal(10, 2)
  stock       Int?
  barcode     String?
  sortOrder   Int         @default(0)
  isAvailable Boolean     @default(true)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

model Product {
  id               String            @id @default(uuid())
  businessId       String
  name             String
  description      String?
  price            Decimal           @db.Decimal(10, 2)
  imageUrl         String?
  isAvailable      Boolean           @default(true)
  category         String?
  categoryId       String?
  templateId       String?
  barcode          String?
  stock            Int?
  lowStockAlert    Int?
  hasVariants      Boolean           @default(false)
  unit             String?
  orderItems       OrderItem[]
  business         Business          @relation(fields: [businessId], references: [id])
  offerProducts    OfferProduct[]
  productCategory  ProductCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryTemplate CategoryTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  variants         ProductVariant[]

  @@index([categoryId])
  @@index([templateId])
  @@index([barcode])
  @@map("products")
}

model Driver {
  id              String             @id @default(uuid())
  userId          String             @unique
  status          DriverStatus       @default(OFFLINE)
  areaId          String
  rating          Float              @default(0)
  vehicleType     String?            @default("MOTORCYCLE")
  platformBalance Decimal            @default(0) @db.Decimal(10, 2)
  area            Area               @relation(fields: [areaId], references: [id])
  user            User               @relation(fields: [userId], references: [id])
  orders          Order[]
  driverReviews   DriverReview[]
  settlements     DriverSettlement[]

  @@map("drivers")
}

model DriverSettlement {
  id        String   @id @default(uuid())
  driverId  String
  amount    Decimal  @db.Decimal(10, 2)
  adminId   String   // The admin who performed the settlement
  createdAt DateTime @default(now())
  driver    Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("driver_settlements")
}

model BusinessSettlement {
  id         String   @id @default(uuid())
  businessId String
  amount     Decimal  @db.Decimal(10, 2)
  adminId    String   // The admin who performed the settlement
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_settlements")
}

model Order {
  id                    String               @id @default(uuid())
  customerId            String
  businessId            String
  driverId              String?
  status                OrderStatus          @default(PENDING)
  paymentMethod         PaymentMethod
  subtotal              Decimal              @db.Decimal(10, 2)
  couponDiscount        Decimal              @default(0) @db.Decimal(10, 2)
  deliveryFee           Decimal              @default(0) @db.Decimal(10, 2)
  driverDeliveryFee     Decimal              @default(0) @db.Decimal(10, 2)
  platformDeliveryFee   Decimal              @default(0) @db.Decimal(10, 2)
  total                 Decimal              @db.Decimal(10, 2)
  couponCode            String?
  couponIssuedBy        String?
  note                  String?
  createdAt             DateTime             @default(now())
  pendingDriverId       String?
  batchId               String?
  deliveryAreaName      String?
  deliveryAddressDetail String?
  items                 OrderItem[]
  statusHistory         OrderStatusHistory[]
  business              Business             @relation(fields: [businessId], references: [id])
  customer              User                 @relation("CustomerOrders", fields: [customerId], references: [id])
  driver                Driver?              @relation(fields: [driverId], references: [id])
  payment               Payment?
  review                Review?
  driverReview          DriverReview?

  @@map("orders")
}

model OrderItem {
  id          String          @id @default(uuid())
  orderId     String
  productId   String
  quantity    Int
  unitPrice   Decimal         @db.Decimal(10, 2)
  variantId   String?
  variantName String?
  order       Order           @relation(fields: [orderId], references: [id])
  product     Product         @relation(fields: [productId], references: [id])
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  changedBy String
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id])

  @@map("order_status_history")
}

model Review {
  id              String   @id @default(uuid())
  orderId         String   @unique
  businessRating  Int
  deliveryRating  Int?
  comment         String?
  createdAt       DateTime @default(now())
  order           Order    @relation(fields: [orderId], references: [id])

  @@map("reviews")
}

model DriverReview {
  id         String   @id @default(uuid())
  orderId    String   @unique
  driverId   String
  businessId String
  rating     Int
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id])
  driver     Driver   @relation(fields: [driverId], references: [id])
  business   Business @relation(fields: [businessId], references: [id])

  @@map("driver_reviews")
}

model SavedAddress {
  id        String   @id @default(uuid())
  userId    String
  label     String
  detail    String
  areaId    String?
  createdAt DateTime @default(now())
  area      Area?    @relation(fields: [areaId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_addresses")
}

model Payment {
  id        String        @id @default(uuid())
  orderId   String        @unique
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  amount    Decimal       @db.Decimal(10, 2)
  createdAt DateTime      @default(now())
  provider  String?
  reference String?       @unique
  updatedAt DateTime      @updatedAt
  order     Order         @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model SystemSettings {
  id                String   @id @default("default")
  defaultCommission Decimal  @default(10.00) @db.Decimal(5, 2)
  baseDeliveryFee   Decimal  @default(3.00) @db.Decimal(10, 2)
  customerAppActive Boolean  @default(true)
  businessAppActive Boolean  @default(true)
  driverAppActive   Boolean  @default(true)
  updatedAt         DateTime @updatedAt

  @@map("system_settings")
}

// ── Offers ──────────────────────────────────────────────────────────────────

model Offer {
  id              String          @id @default(uuid())
  title           String
  description     String?
  rules           String?
  imageUrl        String?
  isActive        Boolean         @default(true)
  type            OfferType       @default(INDIVIDUAL)
  createdAt       DateTime        @default(now())
  offerBusinesses OfferBusiness[]
  offerProducts   OfferProduct[]

  @@map("offers")
}

// Which businesses participate in this offer
model OfferBusiness {
  id         String   @id @default(uuid())
  offerId    String
  businessId String
  offer      Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([offerId, businessId])
  @@map("offer_businesses")
}

// Specific products/categories discounted by this offer
model OfferProduct {
  id            String   @id @default(uuid())
  offerId       String
  productId     String?
  categoryName  String?
  discountPct   Decimal  @db.Decimal(5, 2)
  offer         Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  product       Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("offer_products")
}

// ── Coupons ─────────────────────────────────────────────────────────────────

model Coupon {
  id              String       @id @default(uuid())
  code            String       @unique
  discountType    DiscountType @default(FIXED)
  discountAmount  Decimal      @db.Decimal(10, 2)
  discountPct     Decimal?     @db.Decimal(5, 2)
  maxDiscount     Decimal?     @db.Decimal(10, 2)
  minimumOrder    Decimal      @db.Decimal(10, 2)
  issuedBy        CouponIssuer @default(PLATFORM)
  isActive        Boolean      @default(true)
  maxUses              Int?
  currentUses          Int          @default(0)
  maxTotalDiscount     Decimal?     @db.Decimal(10, 2)
  currentTotalDiscount Decimal      @default(0) @db.Decimal(10, 2)
  createdAt            DateTime     @default(now())

  @@map("coupons")
}

enum DiscountType {
  FIXED
  PERCENTAGE
}

enum CouponIssuer {
  PLATFORM
  BUSINESS
}

enum OfferType {
  INDIVIDUAL
  SHARED
}

enum UserRole {
  CUSTOMER
  BUSINESS
  DRIVER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  ELECTRONIC
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DriverStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum BusinessType {
  FOOD
  STORE
}

enum DeliveryType {
  PLATFORM
  SELF
}
