{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "declaration": true,
    "strict": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@shu/shared-types": ["packages/shared-types/src/index.ts"],
      "@shu/utils": ["packages/utils/src/index.ts"],
      "@shu/ui-components": ["packages/ui-components/src/index.ts"],
      "@shu/api-client": ["packages/api-client/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
